# Copy this file to .env and fill in your values

# Anthropic Claude API key (required for AI features)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key (optional – only needed for Whisper voice transcription)
OPENAI_API_KEY=your_openai_api_key_here

# Secret key for JWT tokens (generate a long random string)
SECRET_KEY=change_this_to_a_long_random_secret_key_minimum_32_chars

# SQLite database path (leave as-is for local development)
DATABASE_URL=sqlite:///data/teammanager.db
